{
  "phase": "super_resolution",
  "config": {
    "run": {
      "name": "smoke_all_phases",
      "output_root": "results/smoke/super_resolution",
      "prompts_path": "/workspace/prompts/smoke_prompts.json",
      "prompt_limit": 2,
      "prompt_categories": [],
      "seeds": [
        7
      ],
      "images_per_prompt": 1,
      "width": 256,
      "height": 256,
      "inference_steps": 2,
      "guidance_scale": 0.0,
      "scheduler": "DDIMScheduler",
      "device": "auto",
      "precision": "auto",
      "smoke_mode": true,
      "allow_mock_fallback": true
    },
    "models": [
      "tiny_sd"
    ],
    "metrics": {
      "enable_clip_score": true,
      "enable_sharpness": true,
      "enable_fid": false
    },
    "reporting": {
      "build_plots": true,
      "build_grids": true
    },
    "feedback": {
      "mode": "mock",
      "gemini_model": "gemini-2.5-flash",
      "iterations": 1,
      "critique_template": "You are helping refine a text-to-image prompt.\nOriginal prompt: {prompt}\nReturn strict JSON with keys:\nalignment_issues, missing_details, style_issues, corrected_prompt, confidence, notes.\n"
    },
    "super_resolution": {
      "backend": "pil",
      "fallback_backend": "pil",
      "model_name": "realesr-general-x4v3",
      "scale": 2,
      "tile": 0
    }
  },
  "environment": {
    "python_version": "3.12.3 (main, Jan 22 2026, 20:57:42) [GCC 13.3.0]",
    "platform": "Linux-6.12.58+-x86_64-with-glibc2.39",
    "system": "Linux",
    "machine": "x86_64",
    "git_commit": "e753f2c33a710ebc0a34b84d511ba672a32ab6bb",
    "cuda_available": false,
    "gpu_name": null,
    "package_versions": {
      "torch": "2.10.0+cu128",
      "diffusers": "0.37.0",
      "transformers": "5.3.0",
      "accelerate": "1.13.0",
      "pydantic": "2.12.5",
      "pandas": "3.0.1",
      "matplotlib": "3.10.8",
      "realesrgan": "not-installed",
      "basicsr": "not-installed"
    }
  }
}